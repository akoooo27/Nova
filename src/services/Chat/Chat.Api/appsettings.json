{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ProviderLogoStorage": {
    "BucketName": "nova-public-assets-dev",
    "Prefix": "providers/",
    "PresignedUrlExpirationMinutes": 10
  },
  "SharedLinks": {
    "PublicBaseUrl": "https://localhost:7001"
  },
  "Arcade": {
    "BaseUrl": "https://api.arcade.dev",
    "GoogleIntegration": {
      "ProviderId": "my-google-provider",
      "Scopes": [ "https://www.googleapis.com/auth/gmail.readonly" ],
      "PostConnectRedirectUri": "https://localhost:7001/settings/integrations"
    }
  }
}
